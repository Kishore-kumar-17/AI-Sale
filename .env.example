# Copy this file to .env and fill in real values. Never commit .env.

# --- Database (Neon PostgreSQL) ---
# Get this from your Neon project dashboard -> Connection Details.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Clerk Authentication ---
# Get these from the Clerk dashboard -> API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard
# Get this from the Clerk dashboard -> Webhooks -> your endpoint -> Signing Secret.
CLERK_WEBHOOK_SIGNING_SECRET=

# --- AI ---
# Used by src/services/research.ts. If NVIDIA_API_KEY is set, it takes priority
# over OPENAI_API_KEY (NVIDIA's NIM API is OpenAI-SDK compatible).
OPENAI_API_KEY=
GEMINI_API_KEY=
# Get a free key at https://build.nvidia.com (NIM API catalog).
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# --- Cloudinary (file storage) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Google (Gmail + Calendar, added in Phase 5) ---
# Create an OAuth 2.0 Client ID (Web application) in Google Cloud Console ->
# APIs & Services -> Credentials, with the Calendar API enabled. Add
# GOOGLE_REDIRECT_URI below as an authorized redirect URI on that client.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# --- n8n (added in Phase 9) ---
N8N_WEBHOOK_URL=
