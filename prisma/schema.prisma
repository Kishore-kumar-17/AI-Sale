// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Synced from Clerk (see src/app/api/webhooks/clerk/route.ts).
// Additional tables (Meetings, Notes, Messages, Research, Proposals, Tasks,
// Activities, Settings, AuditReports) are added phase by phase — see docs/database-schema.md.
model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Phase 5 — Google Calendar connection (see docs/phases/phase-05-meeting-scheduler.md).
  // googleAccessToken/googleTokenExpiry are just a cache of the short-lived access token;
  // googleRefreshToken is what actually keeps the connection alive.
  googleRefreshToken   String?
  googleAccessToken    String?
  googleTokenExpiry    DateTime?
  googleConnectedEmail String?

  leads    Lead[]
  meetings Meeting[]
}

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  MEETING_SCHEDULED
  PROPOSAL_SENT
  WON
  LOST
}

// Phase 2 — CRM System (see docs/phases/phase-02-crm-system.md).
model Lead {
  id        String     @id @default(cuid())
  status    LeadStatus @default(NEW)
  // When `status` last changed — drives Phase 7's "no response after N days" rules.
  // Distinct from `updatedAt`, which bumps on any field edit, not just status changes.
  statusChangedAt DateTime @default(now())

  businessName   String
  ownerName      String?
  category       String?
  phone          String?
  email          String?
  instagram      String?
  website        String?
  address        String?
  city           String?
  state          String?
  country        String?
  followers      Int?
  businessStatus String? // real-world operating status of the business (e.g. Active, Closed) — distinct from the sales pipeline `status` above
  leadSource     String?
  notes          String?

  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String

  research Research?
  messages Message[]
  meetings Meeting[]
  proposal Proposal?
  tasks    Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

// Phase 3 — AI Business Research (see docs/phases/phase-03-ai-business-research.md).
// One research record per lead; regenerating overwrites it (generatedAt tracks the last run).
model Research {
  id     String @id @default(cuid())
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId String @unique

  businessSummary String

  products String[]
  services String[]

  targetAudience String

  strengths String[]
  weaknesses String[]

  websiteSuggestions String[]
  recommendedPages   String[]
  possiblePainPoints String[]

  suggestedCta            String
  recommendedColorPalette String[]

  seoOpportunities           String[]
  googleRankingOpportunities String[]

  generatedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum MessageChannel {
  WHATSAPP
  EMAIL
  LINKEDIN
  INSTAGRAM_DM
}

// Only meaningful for WHATSAPP (a 3-step follow-up sequence); other channels always use FIRST.
enum MessageSequenceStep {
  FIRST
  FOLLOWUP_2
  FOLLOWUP_3
}

// Phase 4 — Personalized Outreach Generator (see docs/phases/phase-04-outreach-generator.md).
// One row per lead/channel/sequence step; regenerating overwrites the existing row.
model Message {
  id     String @id @default(cuid())
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId String

  channel      MessageChannel
  sequenceStep MessageSequenceStep @default(FIRST)
  content      String

  generatedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([leadId, channel, sequenceStep])
  @@index([leadId])
}

enum MeetingType {
  ONLINE
  OFFLINE
}

enum ReminderStatus {
  NOT_SCHEDULED
  SCHEDULED
  SENT
}

// Phase 5 — Meeting Scheduler (see docs/phases/phase-05-meeting-scheduler.md).
model Meeting {
  id     String @id @default(cuid())
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId String

  scheduledAt DateTime
  meetingType MeetingType
  notes       String?

  googleCalendarEventId String?
  googleMeetLink        String?
  reminderStatus        ReminderStatus @default(NOT_SCHEDULED)

  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String

  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([scheduledAt])
}

enum ProposalStatus {
  UNANSWERED
  SENT
  ANSWERED
}

enum ProposalExportFormat {
  PDF
  DOCX
}

// Phase 6 — Proposal Generator (see docs/phases/phase-06-proposal-generator.md).
// One proposal per lead; regenerating overwrites it and resets status/export tracking,
// since the previous content is no longer what would have been sent/answered.
model Proposal {
  id     String @id @default(cuid())
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId String @unique

  introduction       String
  understandingClient String
  problemStatement   String
  solution           String
  features           String[]
  timeline           String[]
  pricing            String
  deliverables       String[]
  support            String
  terms              String[]

  status ProposalStatus @default(UNANSWERED)
  // Set when `status` transitions to SENT — drives Phase 7's "proposal unanswered after 5 days" rule.
  sentAt DateTime?

  lastExportedFormat ProposalExportFormat?
  lastExportedAt     DateTime?

  generatedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum TaskType {
  NO_RESPONSE_3_DAYS
  NO_RESPONSE_7_DAYS
  PROPOSAL_UNANSWERED_5_DAYS
  MEETING_TOMORROW
}

// Phase 7 — Follow-up Automation (see docs/phases/phase-07-followup-automation.md).
// Reminders only — see the Critical Safety Rule in that doc: nothing here ever sends
// a message to a lead automatically.
model Task {
  id     String @id @default(cuid())
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId String

  type    TaskType
  title   String
  dueDate DateTime

  completed   Boolean   @default(false)
  completedAt DateTime?

  // Only set for MEETING_TOMORROW reminders.
  meeting   Meeting? @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([completed])
}
